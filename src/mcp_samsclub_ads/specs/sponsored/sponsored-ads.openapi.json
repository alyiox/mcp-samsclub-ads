          "suggestedBidPhrase": { "type": "number", "format": "double" }
        }
      },
      "KeywordAnalyticsRequest": {
        "type": "object",
        "required": ["advertiserId", "itemIds"],
        "properties": {
          "advertiserId": { "type": "integer", "format": "int64" },
          "itemIds": { "type": "array", "items": { "type": "string" }, "description": "Item IDs (max 10)." },
          "adGroupId": { "type": "integer", "format": "int64" }
        }
      },
      "KeywordAnalyticsResult": {
        "type": "object",
        "properties": {
          "itemId": { "type": "string" },
          "normalizedQuery": { "type": "string" },
          "rawQuery": { "type": "string", "maxLength": 60 },
          "itemKeywordFrequency": { "type": "string", "enum": ["High", "Medium", "Low"] },
          "trafficKeywordFrequency": { "type": "string", "enum": ["High", "Medium", "Low"] }
        }
      },
      "NegativeKeyword": {
        "type": "object",
        "properties": {
          "campaignId": { "type": "integer", "format": "int64" },
          "adGroupId": { "type": "integer", "format": "int64" },
          "keywordId": { "type": "integer", "format": "int64" },
          "keywordText": { "type": "string" },
          "negativeMatchType": { "type": "string", "enum": ["exact", "phrase"] },
          "state": { "type": "string", "enum": ["Enabled", "Paused", "Archived"] }
        }
      },
      "NegativeKeywordCreate": {
        "type": "object",
        "required": ["campaignId", "adGroupId", "negativeMatchType", "state", "keywordText"],
        "properties": {
          "campaignId": { "type": "integer", "format": "int64" },
          "adGroupId": { "type": "integer", "format": "int64" },
          "negativeMatchType": { "type": "string", "enum": ["exact", "phrase"] },
          "state": { "type": "string", "enum": ["Enabled", "Paused", "Archived"] },
          "keywordText": { "type": "string" }
        }
      },
      "NegativeKeywordUpdate": {
        "type": "object",
        "required": ["keywordId", "state"],
        "properties": {
          "keywordId": { "type": "integer", "format": "int64" },
          "state": { "type": "string", "enum": ["Enabled", "Paused", "Archived"] }
        }
      },
      "Placement": {
        "type": "object",
        "properties": {
          "placement": { "type": "string", "enum": ["Search Carousel", "Item Buybox", "Item Carousel"] },
          "status": { "type": "string", "enum": ["enabled", "paused", "archived"] }
        }
      },
      "PlacementMutation": {
        "type": "object",
        "required": ["campaignId", "placements"],
        "properties": {
          "campaignId": { "type": "integer", "format": "int64" },
          "placements": { "type": "array", "items": { "$ref": "#/components/schemas/Placement" } }
        }
      },
      "PlacementMultiplier": {
        "type": "object",
        "required": ["campaignId", "placementType", "multiplier"],
        "properties": {
          "campaignId": { "type": "integer", "format": "int64" },
          "placementType": { "type": "string", "enum": ["Search Ingrid", "Buy-Box"] },
          "multiplier": { "type": "number", "format": "double", "minimum": 0, "maximum": 50000, "description": "Bid adjustment percentage." }
        }
      },
      "PlatformMultiplier": {
        "type": "object",
        "required": ["campaignId", "platformType", "multiplier"],
        "properties": {
          "campaignId": { "type": "integer", "format": "int64" },
          "platformType": { "type": "string", "enum": ["Desktop", "Mobile", "App"] },
          "multiplier": { "type": "number", "format": "double", "minimum": 0, "maximum": 50000, "description": "Bid adjustment percentage." }
        }
      },
      "SnapshotReportRequestV1": {
        "type": "object",
        "required": ["advertiserId", "startDate", "endDate", "attributionWindow", "reportType", "format"],
        "properties": {
          "advertiserId": { "type": "integer", "format": "int64" },
          "startDate": { "type": "string", "format": "date", "description": "yyyy-MM-dd, not the current date." },
          "endDate": { "type": "string", "format": "date", "description": "yyyy-MM-dd, not the current date." },
          "attributionWindow": { "type": "string", "enum": ["days3", "days14", "days30", "allWith14", "all"] },
          "reportType": { "type": "string", "enum": ["keyword", "adItem", "platform", "pageType", "adGroup", "brand", "category", "itemKeyword", "itemHealth", "itemHealthV2", "placement"] },
          "extraFields": { "type": "string", "enum": ["date", "splitAttribution"] },
          "format": { "type": "string", "enum": ["GZIP", "ZIP"] }
        }
      },
      "SnapshotReportRequestV2": {
        "type": "object",
        "required": ["advertiserId", "reportType", "reportMetrics"],
        "description": "Use either reportDate or the startDate/endDate pair, not both.",
        "properties": {
          "advertiserId": { "type": "integer", "format": "int64" },
          "reportType": { "type": "string", "enum": ["keyword", "adItem", "platform", "pageType", "adGroup", "brand", "category", "placement", "videoCampaign", "videoKeywords"] },
          "reportMetrics": { "type": "array", "items": { "type": "string" }, "description": "Selected dimensions and metrics; at least one dimension required." },
          "reportDate": { "type": "string", "format": "date", "description": "Single snapshot date within the last 90 days." },
          "startDate": { "type": "string", "format": "date", "description": "yyyy-MM-dd, not the current date." },
          "endDate": { "type": "string", "format": "date", "description": "yyyy-MM-dd, not the current date." }
        }
      },
      "SnapshotResult": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "enum": ["success", "failure"] },
          "snapshotId": { "type": "string" },
          "jobStatus": { "type": "string", "enum": ["pending", "processing", "done", "failed", "expired"] },
          "details": { "type": "string", "description": "Snapshot file URL when done, or error message." }
        }
      },
      "LatestReportDate": {
        "type": "object",
        "properties": {
          "latestReportDate": { "type": "string", "format": "date", "description": "yyyy-MM-dd" }
        }
      }
    }
  }
