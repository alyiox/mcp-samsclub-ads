{
  "openapi": "3.0.1",
  "info": {
    "title": "Sam's Club Sponsored Ads API",
    "description": "Hand-authored partial OpenAPI spec for the Sam's Club Sponsored Ads (Sam's Advertising Partners) API, built from the developer.samsclub.com reference docs.\n\nSandbox URL: https://developer.api.us.stg.walmart.com/api-proxy/service/sp/api-sams/v1\nProduction URL: https://developer.api.us.walmart.com/api-proxy/service/sp/api-sams/v1 (confirm from partner onboarding docs)\n\nAuthentication uses Walmart-family RSA-SHA256 request signing: WM_CONSUMER.ID, WM_SEC.AUTH_SIGNATURE (Base64 RSA-SHA256), WM_SEC.KEY_VERSION, WM_CONSUMER.INTIMESTAMP (Unix epoch ms), plus Authorization: Bearer <token>. The MCP client injects these headers automatically.\n\nThis spec is partial by design; endpoints not yet modeled (SBA profiles, media, reviews, api-usage, entity/audit snapshots, alerts & recommendations) can still be called via raw method+path.",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "https://developer.api.us.stg.walmart.com/api-proxy/service/sp/api-sams/v1",
      "description": "Sandbox"
    }
  ],
  "security": [
    { "BearerAuth": [] },
    { "consumer_id": [] },
    { "timestamp": [] },
    { "key_version": [] },
    { "auth_signature": [] }
  ],
  "tags": [
    { "name": "Campaigns", "description": "Campaign management" },
    { "name": "Statistics", "description": "Near-real-time campaign metrics and budget cap-out" },
    { "name": "Ad Groups", "description": "Ad group management" },
    { "name": "Ad Items", "description": "Ad item (product) management within ad groups" },
    { "name": "Catalog Item Search", "description": "Search the advertiser catalog for items" },
    { "name": "Keywords", "description": "Keyword management, suggestions, and analytics" },
    { "name": "Negative Keywords", "description": "Negative keyword management" },
    { "name": "Placements", "description": "Campaign placement management" },
    { "name": "Bid Multipliers", "description": "Placement and platform bid multipliers" },
    { "name": "Snapshot Reports v1", "description": "Asynchronous performance report snapshots (v1)" },
    { "name": "Snapshot Reports v2", "description": "Asynchronous performance report snapshots (v2, selectable metrics)" },
    { "name": "Latest Report Date", "description": "Most recent date reports are available" }
  ],
  "paths": {
    "/api/v1/campaigns": {
      "get": {
        "operationId": "CampaignList",
        "summary": "List a specific campaign or all campaigns for an advertiser (excludes deleted)",
        "tags": ["Campaigns"],
        "parameters": [
          { "name": "advertiserId", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" }, "description": "Advertiser ID" },
          { "name": "campaignId", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64" }, "description": "Specific campaign ID to retrieve" },
          { "name": "filter[name]", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Campaign name to search" },
          { "name": "filter[lastModifiedDate]", "in": "query", "required": false, "schema": { "type": "string", "format": "date" }, "description": "Campaigns modified on/after date (yyyy-mm-dd)" }
        ],
        "responses": {
          "200": {
            "description": "List of campaigns",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Campaign" } } } }
          }
        }
      },
      "post": {
        "operationId": "CampaignCreate",
        "summary": "Create new campaigns in draft state (max 50 per batch)",
        "tags": ["Campaigns"],
        "parameters": [
          { "name": "advertiserId", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" }, "description": "Advertiser ID" }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CampaignCreate" } } } }
        },
        "responses": {
          "200": {
            "description": "Per-campaign create result",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CampaignResult" } } } }
          }
        }
      },
      "put": {
        "operationId": "CampaignUpdate",
        "summary": "Update existing campaigns (max 50 per batch)",
        "tags": ["Campaigns"],
        "parameters": [
          { "name": "advertiserId", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64" }, "description": "Advertiser ID" }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CampaignUpdate" } } } }
        },
        "responses": {
          "200": {
            "description": "Per-campaign update result",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CampaignResult" } } } }
          }
        }
      }
    },
    "/api/v1/campaigns/delete": {
      "put": {
        "operationId": "CampaignDelete",
        "summary": "Delete scheduled-but-not-live campaigns (max 50 per batch)",
        "tags": ["Campaigns"],
        "parameters": [
          { "name": "advertiserId", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64" }, "description": "Advertiser ID" }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "array", "items": { "type": "object", "required": ["campaignId"], "properties": { "campaignId": { "type": "integer", "format": "int64" } } } } } }
        },
        "responses": {
          "200": {
            "description": "Per-campaign delete result",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CampaignResult" } } } }
          }
        }
      }
