          "details": { "type": "string", "description": "Error details when code is failure." }
        }
      },
      "CampaignResult": {
        "allOf": [
          { "$ref": "#/components/schemas/MutationResult" },
          { "type": "object", "properties": { "campaignId": { "type": "integer", "format": "int64" } } }
        ]
      },
      "AdGroupResult": {
        "allOf": [
          { "$ref": "#/components/schemas/MutationResult" },
          { "type": "object", "properties": { "adGroupId": { "type": "integer", "format": "int64" } } }
        ]
      },
      "AdItemResult": {
        "allOf": [
          { "$ref": "#/components/schemas/MutationResult" },
          { "type": "object", "properties": { "adItemId": { "type": "integer", "format": "int64" } } }
        ]
      },
      "KeywordResult": {
        "allOf": [
          { "$ref": "#/components/schemas/MutationResult" },
          { "type": "object", "properties": { "keywordId": { "type": "integer", "format": "int64" }, "keywordText": { "type": "string" } } }
        ]
      },
      "PlacementMultiplierResult": {
        "allOf": [
          { "$ref": "#/components/schemas/MutationResult" },
          { "type": "object", "properties": { "placementMultiplierId": { "type": "integer", "format": "int64" } } }
        ]
      },
      "PlatformMultiplierResult": {
        "allOf": [
          { "$ref": "#/components/schemas/MutationResult" },
          { "type": "object", "properties": { "platformMultiplierId": { "type": "integer", "format": "int64" } } }
        ]
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "campaignId": { "type": "integer", "format": "int64" },
          "advertiserId": { "type": "integer", "format": "int64" },
          "name": { "type": "string", "maxLength": 255 },
          "campaignType": { "type": "string", "enum": ["sponsoredProducts", "sba"] },
          "targetingType": { "type": "string", "enum": ["manual", "auto"] },
          "status": { "type": "string", "enum": ["enabled", "paused", "completed", "extend", "proposal"] },
          "budgetType": { "type": "string", "enum": ["daily", "total", "both"] },
          "startDate": { "type": "string", "format": "date" },
          "endDate": { "type": "string", "format": "date" },
          "totalBudget": { "type": "number", "format": "double" },
          "dailyBudget": { "type": "number", "format": "double" },
          "rollover": { "type": "boolean" }
        }
      },
      "CampaignCreate": {
        "type": "object",
        "required": ["advertiserId"],
        "properties": {
          "advertiserId": { "type": "integer", "format": "int64" },
          "name": { "type": "string", "maxLength": 255, "description": "Unique campaign name." },
          "campaignType": { "type": "string", "enum": ["sponsoredProducts", "sba"] },
          "targetingType": { "type": "string", "enum": ["manual", "auto"] },
          "status": { "type": "string", "enum": ["enabled", "paused", "completed", "extend", "proposal"] },
          "budgetType": { "type": "string", "enum": ["daily", "total", "both"] },
          "startDate": { "type": "string", "format": "date" },
          "endDate": { "type": "string", "format": "date", "description": "Use 9999-12-30 for indefinite." },
          "totalBudget": { "type": "number", "format": "double" },
          "dailyBudget": { "type": "number", "format": "double" },
          "rollover": { "type": "boolean", "description": "Currently accepts only true." }
        }
      },
      "CampaignUpdate": {
        "type": "object",
        "required": ["campaignId", "name", "status"],
        "properties": {
          "campaignId": { "type": "integer", "format": "int64" },
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["enabled", "paused", "completed", "extend", "proposal"] }
        }
      },
      "CampaignStats": {
        "type": "object",
        "properties": {
          "campaignId": { "type": "integer", "format": "int64" },
          "todayAdSpend": { "type": "number", "format": "double" },
          "asOf": { "type": "string", "description": "PST capture timestamp (24-hour)." },
          "adGroupId": { "type": "integer", "format": "int64", "description": "Deprecated; returns -1." },
          "dailyOutOfBudgetDatetime": { "type": "string", "nullable": true },
          "dailyRemainingBudget": { "type": "number", "format": "double", "nullable": true },
          "todayImpressions": { "type": "integer", "format": "int64" },
          "todayClicks": { "type": "integer", "format": "int64" }
        }
      },
      "AdGroup": {
        "type": "object",
        "properties": {
          "adGroupId": { "type": "integer", "format": "int64" },
          "campaignId": { "type": "integer", "format": "int64" },
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["enabled", "disabled", "deleted"] }
        }
      },
      "AdGroupCreate": {
        "type": "object",
        "required": ["campaignId"],
        "properties": {
          "campaignId": { "type": "integer", "format": "int64" },
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["enabled", "disabled"] }
        }
      },
      "AdGroupUpdate": {
        "type": "object",
        "required": ["adGroupId"],
        "properties": {
          "adGroupId": { "type": "integer", "format": "int64" },
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["enabled", "disabled", "deleted"] }
        }
      },
      "AdItem": {
        "type": "object",
        "properties": {
          "campaignId": { "type": "integer", "format": "int64" },
          "adGroupId": { "type": "integer", "format": "int64" },
          "adItemId": { "type": "integer", "format": "int64" },
          "itemId": { "type": "string" },
          "bid": { "type": "number", "format": "double" },
          "status": { "type": "string" },
          "name": { "type": "string" },
          "itemImageUrl": { "type": "string" },
          "itemPageUrl": { "type": "string" },
          "reviewStatus": { "type": "string" },
          "reviewReason": { "type": "string" }
        }
      },
      "AdItemUpsert": {
        "type": "object",
        "required": ["campaignId", "adGroupId", "itemId", "bid", "status"],
        "properties": {
          "campaignId": { "type": "integer", "format": "int64" },
          "adGroupId": { "type": "integer", "format": "int64" },
          "itemId": { "type": "string" },
          "bid": { "type": "number", "format": "double" },
          "status": { "type": "string", "enum": ["enabled", "disabled", "deleted"] }
        }
      },
      "ItemSearchRequest": {
        "type": "object",
        "required": ["advertiserId"],
        "description": "Provide either searchText or searchItemIds, not both.",
        "properties": {
          "advertiserId": { "type": "integer", "format": "int64" },
          "searchText": { "type": "string", "description": "Terms to match item name/description." },
          "searchItemIds": { "type": "array", "items": { "type": "string" }, "description": "Primary or variant item IDs (max 200)." }
        }
      },
      "ItemSearchResult": {
        "type": "object",
        "properties": {
          "itemId": { "type": "string" },
          "itemName": { "type": "string" },
          "itemImageUrl": { "type": "string" },
          "itemPageUrl": { "type": "string" },
          "suggestedBid": { "type": "number", "format": "double" },
          "variantItems": { "type": "array", "items": { "$ref": "#/components/schemas/VariantItem" } }
        }
      },
      "VariantItem": {
        "type": "object",
        "properties": {
          "variantItemId": { "type": "string" },
          "variantItemName": { "type": "string" },
          "variantImageUrl": { "type": "string" }
        }
      },
      "Keyword": {
        "type": "object",
        "properties": {
          "campaignId": { "type": "integer", "format": "int64" },
          "adGroupId": { "type": "integer", "format": "int64" },
          "keywordId": { "type": "integer", "format": "int64" },
          "keywordText": { "type": "string" },
          "matchType": { "type": "string", "enum": ["exact", "phrase", "broad"] },
          "bid": { "type": "number", "format": "double" },
          "state": { "type": "string", "enum": ["Enabled", "Paused", "Archived"] },
          "status": { "type": "string", "enum": ["approved", "pending", "rejected"] }
        }
      },
      "KeywordCreate": {
        "type": "object",
        "required": ["campaignId", "adGroupId", "matchType", "bid", "state", "keywordText"],
        "properties": {
          "campaignId": { "type": "integer", "format": "int64" },
          "adGroupId": { "type": "integer", "format": "int64" },
          "matchType": { "type": "string", "enum": ["exact", "phrase", "broad"] },
          "bid": { "type": "number", "format": "double", "description": "CPC in dollars." },
          "state": { "type": "string", "enum": ["Enabled", "Paused", "Archived"] },
          "keywordText": { "type": "string", "maxLength": 80 }
        }
      },
      "KeywordUpdate": {
        "type": "object",
        "required": ["keywordId"],
        "properties": {
          "keywordId": { "type": "integer", "format": "int64" },
          "bid": { "type": "number", "format": "double", "description": "CPC in dollars (max $100)." },
          "state": { "type": "string", "enum": ["Enabled", "Paused", "Archived"] }
        }
      },
      "KeywordSuggestion": {
        "type": "object",
        "properties": {
          "score": { "type": "number", "format": "double" },
          "query": { "type": "string" },
          "suggestedBid": { "type": "number", "format": "double" },
          "suggestedBidBroad": { "type": "number", "format": "double" },
