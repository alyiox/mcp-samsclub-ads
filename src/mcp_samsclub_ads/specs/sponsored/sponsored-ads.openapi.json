    "/api/v1/latestReportDate": {
      "get": {
        "operationId": "LatestReportDate",
        "summary": "Get the most recent date for which reports are available",
        "tags": ["Latest Report Date"],
        "responses": {
          "200": {
            "description": "Latest report date",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/LatestReportDate" } } } }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": { "type": "http", "scheme": "bearer", "description": "Environment-specific auth token (Authorization: Bearer <token>)." },
      "consumer_id": { "type": "apiKey", "in": "header", "name": "WM_CONSUMER.ID", "description": "Consumer ID provided by Sam's Club." },
      "timestamp": { "type": "apiKey", "in": "header", "name": "WM_CONSUMER.INTIMESTAMP", "description": "Unix epoch (ms) timestamp the signature was generated for." },
      "key_version": { "type": "apiKey", "in": "header", "name": "WM_SEC.KEY_VERSION", "description": "Signing key version." },
      "auth_signature": { "type": "apiKey", "in": "header", "name": "WM_SEC.AUTH_SIGNATURE", "description": "Base64 RSA-SHA256 request signature." }
    },
    "schemas": {
      "MutationResult": {
        "type": "object",
